generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @default("Administrator")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MediaAsset {
  id                 String              @id @default(cuid())
  key                String              @unique
  bucket             String
  url                String?
  filename           String
  contentType        String
  size               Int
  kind               String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  featuredProjects   FeaturedProject[]
  heroSlides         HeroSlide[]
  productDownloads   ProductDownload[]
  productImages      ProductImage[]
  technologyPartners TechnologyPartner[]
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  icon        String    @default("pixel")
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id                  String            @id @default(cuid())
  categoryId          String
  name                String
  slug                String            @unique
  series              String            @default("Commercial Series")
  family              String?
  shortDescription    String?
  description         String
  badges              Json              @default("[]")
  keyDetails          Json              @default("[]")
  basicSpecs          Json              @default("[]")
  technicalDetails    Json              @default("[]")
  installationMethods Json              @default("[]")
  availableModels     Json              @default("[]")
  seoTitle            String?
  seoDescription      String?
  isActive            Boolean           @default(true)
  isFeatured          Boolean           @default(false)
  sortOrder           Int               @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  category            ProductCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  downloads           ProductDownload[]
  images              ProductImage[]
  models              ProductModel[]
  specs               ProductSpec[]
}

model ProductImage {
  id        String      @id @default(cuid())
  productId String
  mediaId   String?
  url       String?
  alt       String?
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  media     MediaAsset? @relation(fields: [mediaId], references: [id])
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductDownload {
  id        String     @id @default(cuid())
  productId String
  mediaId   String
  type      String
  label     String
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  media     MediaAsset @relation(fields: [mediaId], references: [id])
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, type])
}

model ProductSpec {
  id        String   @id @default(cuid())
  productId String
  group     String
  label     String
  value     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductModel {
  id        String   @id @default(cuid())
  productId String
  model     String
  length    String?
  power     String?
  beam      String?
  output    String?
  colour    String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model HeroSlide {
  id        String      @id @default(cuid())
  title     String
  eyebrow   String
  copy      String
  imageUrl  String
  mediaId   String?
  align     String      @default("object-center")
  sortOrder Int         @default(0)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  media     MediaAsset? @relation(fields: [mediaId], references: [id])
}

model FeaturedProject {
  id        String      @id @default(cuid())
  name      String
  location  String
  imageUrl  String
  mediaId   String?
  sortOrder Int         @default(0)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  media     MediaAsset? @relation(fields: [mediaId], references: [id])
}

model TechnologyPartner {
  id        String      @id @default(cuid())
  name      String
  imageUrl  String
  mediaId   String?
  sortOrder Int         @default(0)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  media     MediaAsset? @relation(fields: [mediaId], references: [id])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PublishedSnapshot {
  id          String   @id @default(cuid())
  key         String   @unique
  data        Json
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
